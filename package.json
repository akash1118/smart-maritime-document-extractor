{
  "name": "smde-backend",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc && cp -r src/prompts/*.txt dist/prompts/",
    "start": "node dist/app.js",
    "prisma:generate": "prisma generate --schema=src/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/db/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=src/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
